# Haruki Sekai Asset Updater local/compose environment

# Docker / compose
HTTP_PORT=8080
RUST_LOG=info
MALLOC_ARENA_MAX=2

# Local runtime config path override
# HARUKI_CONFIG_PATH=./haruki-asset-configs.yaml

# AssetStudio CLI path
# Local run: absolute path on your machine
# Docker compose: leave empty and let the container default point at /app/assetstudio/AssetStudioCLI
HARUKI_ASSET_STUDIO_CLI_PATH=

# Required when using the tracked local config (haruki-asset-configs.yaml)
# Shared key/iv are used by JP/TW/KR/CN in the local config.
HARUKI_SHARED_AES_KEY_HEX=
HARUKI_SHARED_AES_IV_HEX=

# EN-specific key/iv used by the local config.
HARUKI_EN_AES_KEY_HEX=
HARUKI_EN_AES_IV_HEX=

# Optional if you later switch config values to env references for auth/storage/git.
# HARUKI_BEARER_TOKEN=
# HARUKI_STORAGE_ACCESS_KEY=
# HARUKI_STORAGE_SECRET_KEY=
# HARUKI_GIT_SYNC_PASSWORD=
